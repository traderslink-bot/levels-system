{
  "name": "levels-system-phase1",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test src/tests/**/*.test.ts",
    "manual:test": "tsx src/scripts/run-manual-level-test.ts",
    "watchlist:test": "tsx src/scripts/run-watchlist-monitor-sample.ts",
    "alert:test": "tsx src/scripts/run-alert-intelligence-sample.ts",
    "watchlist:alerts:test": "tsx src/scripts/run-watchlist-alerts-sample.ts",
    "watchlist:manual": "tsx src/runtime/manual-watchlist-server.ts",
    "snapshot:level-analysis": "tsx src/scripts/run-level-analysis-snapshot.ts",
    "snapshot:level-analysis:review": "tsx src/scripts/run-level-analysis-snapshot.ts --symbol SNAP --as-of 2026-05-01T10:20:00-04:00 --reference-price 10.68 --candles-5m docs/examples/level-analysis-snapshot/sample-5m-candles.json --candles-15m docs/examples/level-analysis-snapshot/sample-15m-candles.json --candles-4h docs/examples/level-analysis-snapshot/sample-4h-candles.json --candles-daily docs/examples/level-analysis-snapshot/sample-daily-candles.json --previous-close 9.1 --out docs/examples/level-analysis-snapshot/latest-level-analysis-snapshot.json",
    "snapshot:level-analysis:smoke": "tsx src/scripts/run-level-analysis-snapshot.ts --symbol SNAP --as-of 2026-05-01T10:20:00-04:00 --reference-price 10.68 --candles-5m docs/examples/level-analysis-snapshot/sample-5m-candles.json --candles-15m docs/examples/level-analysis-snapshot/sample-15m-candles.json --candles-4h docs/examples/level-analysis-snapshot/sample-4h-candles.json --candles-daily docs/examples/level-analysis-snapshot/sample-daily-candles.json --previous-close 9.1 --out artifacts/level-analysis-snapshot-smoke/SNAP/1777645200000/level-analysis-snapshot-v1.json",
    "snapshot:level-analysis:batch:real-cache": "tsx src/scripts/run-level-analysis-snapshot-real-cache-batch.ts",
    "manifest:level-analysis:snapshots": "tsx src/scripts/run-level-analysis-snapshot-batch-manifest.ts",
    "manifest:level-analysis:snapshots:review": "tsx src/scripts/run-level-analysis-snapshot-batch-manifest.ts --input docs/examples/level-analysis-snapshot/latest-level-analysis-snapshot.json --out docs/examples/level-analysis-snapshot/batch-manifest/latest-level-analysis-snapshot-batch-manifest.json --output-root docs/examples/level-analysis-snapshot --batch-id level-analysis-snapshot-review-batch --generated-at 2026-06-01T00:00:00.000Z",
    "review:level-quality": "tsx src/scripts/run-level-quality-review.ts",
    "cache:collect:15m": "tsx src/scripts/collect-15m-validation-cache.ts",
    "validation:levels:live": "tsx src/scripts/run-level-candle-health-check.ts",
    "validation:levels:persistence": "tsx src/scripts/run-level-persistence-validation.ts",
    "validation:levels:forward": "tsx src/scripts/run-forward-reaction-validation.ts",
    "validation:levels:batch": "tsx src/scripts/run-level-validation-batch.ts",
    "validation:live": "tsx src/scripts/run-live-opportunity-validation.ts",
    "validation:test": "tsx src/scripts/run-opportunity-validation-sample.ts",
    "validation:summary": "tsx src/scripts/summarize-opportunity-validations.ts",
    "validation:recovery": "tsx src/scripts/scan-opportunity-recovery-windows.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@stoqey/ib": "^1.5.3",
    "dotenv": "^17.4.2"
  }
}
